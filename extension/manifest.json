{
  "manifest_version": 3,
  "name": "Google Chat API Bridge",
  "version": "1.0.0",
  "description": "Bridges the google-chat-api Node.js library to the browser for cookie-free authentication",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://chat.google.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/chat/*",
        "https://chat.google.com/*"
      ],
      "js": ["scripts/interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://mail.google.com/chat/*",
        "https://chat.google.com/*"
      ],
      "js": ["scripts/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google Chat API Bridge"
  }
}
