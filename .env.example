# Example environment config (copy to `.env`)
#
# This repo ships a CLI (`gchat`), a local HTTP API server, and a TypeScript library.
# Most settings are optional; flags still take precedence.

# Where auth/cache files are stored (default: ~/.gchat)
# GCHAT_CACHE_DIR=/absolute/path/to/cache

# Where local state (favorites/hidden/etc) is stored (defaults to GCHAT_CACHE_DIR)
# GCHAT_DATA_DIR=/absolute/path/to/data

# Logging: error | warn | info | debug | silent
# LOG_LEVEL=info

# ── Chrome Extension Authentication ──────────────────────────────────────────
# Extension auth is ON by default. All API requests are proxied through the
# Chrome extension so cookies are never extracted by Node.js.
# Set to "false" to fall back to cookie extraction (legacy behaviour).
# GCHAT_EXTENSION_AUTH=false

# Host/port the local WebSocket bridge server listens on.
# The extension connects to this address.  Default: 0.0.0.0:7891
# (0.0.0.0 binds all interfaces so both IPv4 127.0.0.1 and IPv6 ::1 work.)
#
# To restrict to localhost only:
#   GCHAT_EXTENSION_HOST=127.0.0.1
#
# To run on a different port:
#   GCHAT_EXTENSION_PORT=8000
#
# The Chrome extension defaults to connecting to localhost:7891.
# Change the extension's server address from the popup (host:port field)
# or via the SET_SERVER message from background.js.
# GCHAT_EXTENSION_HOST=0.0.0.0
# GCHAT_EXTENSION_PORT=7891

# ── Timestamps ───────────────────────────────────────────────────────────────
# IANA timezone for human-readable timestamps in API responses (default: UTC).
# GCHAT_TIMEZONE=Europe/London
